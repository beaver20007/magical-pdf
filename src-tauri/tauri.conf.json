{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Magical PDF Listva",
  "version": "0.1.0",
  "identifier": "com.magicalpdf.listva",
  "build": {
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Magical PDF Listva",
        "width": 1180,
        "height": 820,
        "minWidth": 860,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; script-src 'self' 'unsafe-inline' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: asset: http://asset.localhost; worker-src 'self' blob: asset: http://asset.localhost; connect-src 'self' asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
